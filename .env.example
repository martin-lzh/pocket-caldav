# Copy this file to .env before starting Docker Compose.
# For a normal HTTPS reverse-proxy deployment, PUBLIC_BASE_URL is the only value
# you must change. Leave API key and users empty to let the server/CLI manage them.

# Required for production: public HTTPS origin used in generated attachment URLs.
PUBLIC_BASE_URL=https://calendar.example.com

# Optional comma-separated Host allowlist. Leave empty to derive it from
# PUBLIC_BASE_URL while still allowing localhost/127.0.0.1 health checks.
ALLOWED_HOSTS=

# Usually keep these defaults when Caddy/nginx runs on the same host.
# Use 127.0.0.1 when Caddy/nginx terminates HTTPS on the same server.
# Use 0.0.0.0 only if you intentionally expose the service directly.
HOST_BIND=127.0.0.1
HOST_PORT=5232

# Optional: fixed API key for all /api/* management calls.
# Leave empty to generate and store one in /data/api_key.txt on first startup.
CALDAV_API_KEY=

# Optional: fixed CalDAV users. Use either comma-separated users or JSON.
# Leave empty and run `docker compose exec caldav python server.py cli` to create users.
CALDAV_USERS=
# CALDAV_USERS=main:replace-main-password
# CALDAV_USERS={"main":"replace-main-password","shared":"replace-shared-password"}

# Attachment cleanup settings.
ATTACHMENT_TTL_DAYS=365
CLEANUP_INTERVAL_SECONDS=3600

# Request size limits. Keep Caddy's request_body limit at or below these values.
MAX_ICS_BYTES=1048576
MAX_ATTACHMENT_BYTES=26214400
MAX_REQUEST_BYTES=31457280
